<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Digital Imagination | Store</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body { background-color: #1b2838; color: white; font-family: sans-serif; }
        .container { width: 80%; margin: auto; }
        .game-card { 
            background-color: #16202d; 
            padding: 15px; 
            margin: 10px 0; 
            border-radius: 5px;
            display: flex;
            justify-content: space-between;
        }
        .price { color: #66c0f4; font-weight: bold; }
    </style>
</head>
<body>
    <nav style="background: #171a21; padding: 15px; display: flex; gap: 20px;">
        <a href="/" style="color: white; text-decoration: none;">STORE</a>
        <a href="/library" style="color: white; text-decoration: none;">LIBRARY</a>
        <a href="/login" style="color: white; text-decoration: none;">LOGIN</a>
    </nav>
    <div class="container">
        <h1>Digital Imagination Store</h1>
        <hr>
        <div class="game-list">
            <% games.forEach(game => { %>
                <div class="game-card">
                    <div>
                        <h3><%= game.title %></h3>
                        <p><%= game.description %></p>
                        <small>Category: <%= game.category %></small>
                    </div>
                    <div class="price">$<%= game.price %></div>
                </div>
            <% }); %>
        </div>
    </div>
</body>
</html>
