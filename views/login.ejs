<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>DI | Login</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body { background-color: #1b2838; color: white; font-family: sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; }
        .login-box { background: #16202d; padding: 40px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.5); }
        input { display: block; width: 100%; margin: 10px 0; padding: 10px; border-radius: 4px; border: none; }
        button { width: 100%; padding: 10px; background: #66c0f4; border: none; color: white; cursor: pointer; }
    </style>
</head>
<body>
    <nav style="background: #171a21; padding: 15px; display: flex; gap: 20px;">
        <a href="/" style="color: white; text-decoration: none;">STORE</a>
        <a href="/library" style="color: white; text-decoration: none;">LIBRARY</a>
        <a href="/login" style="color: white; text-decoration: none;">LOGIN</a>
    </nav>
    <div class="login-box">
        <h2>Sign In</h2>
        <form action="/login" method="POST">
            <input type="text" name="username" placeholder="Username" required>
            <input type="password" name="password" placeholder="Password" required>
            <button type="submit">Login</button>
        </form>
        <div class="login-footer">
            <p>Don't have an account?</p>
            <a href="/register" class="btn-secondary">Join Mini-Steam</a>
        </div>
    </div>
</body>
</html>
