<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Digital Imagination | Store</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body { background-color: #1b2838; color: white; font-family: sans-serif; }
        .container { width: 80%; margin: auto; }
        .game-card { 
            background-color: #16202d; 
            padding: 15px; 
            margin: 10px 0; 
            border-radius: 5px;
            display: flex;
            justify-content: space-between;
        }
        .price { color: #66c0f4; font-weight: bold; }
        .cart-link { float: right; color: #66c0f4; text-decoration: none; font-weight: bold; }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="container">
        <% if (typeof added !== 'undefined') { %>
            <div style="background: #47b230; color: white; padding: 10px; margin-bottom: 20px; border-radius: 3px;">
                ✔ <%= added %> added to your cart!
            </div>
        <% } %>
        <h1>Digital Imagination Store</h1>
        <hr>
        <div class="game-list">
            <% games.forEach(game => { %>
                <div class="game-card">
                    <div>
                        <h3><%= game.title %></h3>
                        <p><%= game.description %></p>
                        <p>$<%= game.price %></p>
                        <small>Category: <%= game.category %></small>
                        
                        <% if (game.library_id) { %>
                            <button class="btn-in-library" disabled>IN LIBRARY</button>
                        <% } else { %>
                            <form action="/cart/add" method="POST">
                                <input type="hidden" name="gameId" value="<%= game.game_id %>">
                                <input type="hidden" name="gameTitle" value="<%= game.title %>">
                                <button type="submit" class="btn-buy">Add to Cart</button>
                            </form>
                        <% } %>
                    </div>
                    <div class="price">$<%= game.price %></div>
                </div>
            <% }); %>
        </div>
    </div>
</body>
</html>