<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>DI | My Library</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body { background-color: #1b2838; color: white; font-family: sans-serif; }
        .container { width: 80%; margin: auto; }
        .game-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
        .game-item { background: #2a475e; padding: 20px; border-radius: 5px; text-align: center; }
        .btn-play { background: #5c7e10; color: white; padding: 10px; text-decoration: none; border-radius: 2px; }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="container">
        <h1>Your Game Library</h1>
        <h2>Welcome back, <%= username %>!</h2>

        <% if (typeof message !== 'undefined' && message === 'ReviewSubmitted') { %>
            <div style="background: #47b230; color: white; padding: 15px; margin: 20px 0; border-radius: 5px; text-align: center; font-weight: bold;">
                ✔ Review Submitted Successfully!
            </div>
        <% } %>

        <hr>
        <div class="game-grid">
            <% if (games.length === 0) { %>
                <p>Your library is empty. Head to the <a href="/" style="color: #66c0f4;">Store</a> to add some games!</p>
            <% } else { %>
                <% games.forEach(game => { %>
                    <div class="game-item">
                        <h3><%= game.title %></h3>
                        <br>
                        <a href="#" class="btn-play">PLAY</a>
                        
                        <% if (!game.review_id) { %>
                            <a href="/review/write/<%= game.game_id %>" class="btn-play" style="background: #4c6c8c;">GIVE REVIEW</a>
                        <% } else { %>
                            <p style="color: #47b230; margin-top: 10px; font-size: 0.9em;">✔ Reviewed</p>
                        <% } %>
                    </div>
                <% }); %>
            <% } %>
        </div>
    </div>
</body>
</html>
