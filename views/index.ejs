<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Digital Imagination | Store</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body { background-color: #1b2838; color: white; font-family: sans-serif; }
        .container { width: 80%; margin: auto; }
        .game-card { 
            background-color: #16202d; 
            padding: 15px; 
            margin: 10px 0; 
            border-radius: 5px;
            display: flex;
            justify-content: space-between;
        }
        .price { color: #66c0f4; font-weight: bold; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Digital Imagination Store</h1>
        <hr>
        <div class="game-card">
            <div>
                <h3>Featured Game: Neon Samurai</h3>
                <p>High-speed combat in a cyberpunk Kyoto.</p>
            </div>
            <div class="price">$49.99</div>
        </div>
    </div>
</body>
</html>
