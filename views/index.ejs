<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Digital Imagination | Store</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body { background-color: #1b2838; color: white; font-family: sans-serif; }
        .container { width: 80%; margin: auto; }
        .game-card { 
            background-color: #16202d; 
            padding: 15px; 
            margin: 10px 0; 
            border-radius: 5px;
            display: flex;
            justify-content: space-between;
        }
        .price { color: #66c0f4; font-weight: bold; }
        .cart-link { float: right; color: #66c0f4; text-decoration: none; font-weight: bold; }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="container">
        <% if (typeof added !== 'undefined') { %>
            <div style="background: #47b230; color: white; padding: 10px; margin-bottom: 20px; border-radius: 3px;">
                ✔ <%= added %> added to your cart!
            </div>
        <% } %>
        <h1>Digital Imagination Store</h1>
        <hr>
        <div class="game-list">
            <% games.forEach(game => { %>
                <div class="game-card" style="align-items: center;">
                    <div style="flex: 0 0 150px; margin-right: 20px;">
                        <img src="<%= game.image_url %>" alt="<%= game.title %>" 
                            style="width: 100%; border-radius: 4px; box-shadow: 0 4px 8px rgba(0,0,0,0.5);">
                    </div>

                    <div style="flex-grow: 1;">
                        <h3><%= game.title %></h3>
                        <p><%= game.description %></p>
                        
                        <p>
                            Current Review Score: 
                            <% if (game.avg_rating) { %>
                                <span style="color: #ffc107;"><%= Number(game.avg_rating).toFixed(1) %>/6</span>
                            <% } else { %>
                                <span style="color: #888;">No reviews yet</span>
                            <% } %>
                        </p>

                        <small>Category: <%= game.category %></small>
                        
                        <div style="margin-top: 10px;">
                            <% if (game.library_id) { %>
                                <button class="btn-in-library" disabled style="...">IN LIBRARY</button>
                            <% } else { %>
                                <form action="/cart/add" method="POST" style="display: inline;">
                                    <input type="hidden" name="gameId" value="<%= game.game_id %>">
                                    <input type="hidden" name="gameTitle" value="<%= game.title %>">
                                    <button type="submit" class="btn-buy" style="...">Add to Cart</button>
                                </form>
                            <% } %>

                            <div style="margin-top: 10px;">
                                <a href="/game/<%= game.game_id %>" style="color: #66c0f4; text-decoration: none; font-size: 0.9em;">
                                    Read Reviews
                                </a>
                            </div>
                        </div>
                    </div>
                    <div class="price" style="font-size: 1.2em;">$<%= game.price %></div>
                </div>
            <% }); %>
        </div>
    </div>
</body>
</html>